# The full Content-Security-Policy is emitted per page as a <meta> by Astro's
# `security.csp` (astro.config.mjs) — it carries SHA-256 hashes for inline
# scripts/styles, which a static header cannot. Here we only set the directive
# that a <meta> CSP cannot enforce (frame-ancestors) plus the other security
# headers. Keep this header CSP free of fetch directives so it does not
# intersect with (and re-block) the hashed meta policy.
/*
  Content-Security-Policy: frame-ancestors 'self'
  X-Prismatica-CSP-Mode: production
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Self-hosted fonts are immutable per family name — cache them hard.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
