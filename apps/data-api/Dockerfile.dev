# ============================================
# data-api — Fast dev Dockerfile
# ============================================
# No TS compilation at build time: tsx runs TS directly.
# Source is volume-mounted for hot-reload.
# After initial build (~30s), rebuilds are instant (cached layers).
# ============================================

FROM node:22-alpine

# Install pnpm + bash + psql client + mongosh build deps
RUN corepack enable && corepack prepare pnpm@latest --activate \
 && apk add --no-cache bash postgresql16-client python3 make g++ \
 && npm install -g mongosh --ignore-scripts=false 2>&1 \
 && apk del python3 make g++ \
 && rm -rf /root/.npm /tmp/*

WORKDIR /app

# ── Install deps (cached layer) ─────────────────────
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# ── Copy source (overridden by volume mount in dev) ──
COPY tsconfig.json ./
COPY src/ ./src/

ENV NODE_ENV=development
ENV DATA_API_PORT=3001
EXPOSE 3001

HEALTHCHECK --interval=5s --timeout=2s --retries=10 \
  CMD wget -qO- http://localhost:3001/health || exit 1

# tsx watch for hot-reload in dev
CMD ["pnpm", "run", "dev"]
