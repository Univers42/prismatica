# syntax=docker/dockerfile:1
# ============================================
# data-api — Fast dev Dockerfile
# ============================================
# No TS compilation at build time: tsx runs TS directly.
# Source is volume-mounted for hot-reload.
#
# Optimized: BuildKit cache mounts for pnpm store + apk.
# ============================================

FROM node:22-alpine

LABEL org.opencontainers.image.title="prismatica-api-dev" \
      org.opencontainers.image.description="Prismatica data-api — development mode" \
      org.opencontainers.image.source="https://github.com/dlesieur/prismatica"

ENV PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH" \
    NODE_ENV=development \
    DATA_API_PORT=3001

RUN --mount=type=cache,id=apk-dev,target=/var/cache/apk \
    corepack enable && corepack prepare pnpm@9.15.0 --activate \
 && apk add bash postgresql16-client

WORKDIR /app

# ── Install deps (cached via mount) ─────────────────
COPY package.json pnpm-lock.yaml* ./
RUN --mount=type=cache,id=pnpm-api-dev,target=/pnpm/store \
    pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# ── Copy source (overridden by volume mount in dev) ──
COPY tsconfig.json ./
COPY src/ ./src/

EXPOSE 3001

HEALTHCHECK --interval=5s --timeout=2s --start-period=10s --retries=10 \
  CMD wget -qO- http://127.0.0.1:3001/health || exit 1

# tsx watch for hot-reload in dev
CMD ["pnpm", "run", "dev"]
