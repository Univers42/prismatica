# Settings shared between npm (fallback) and pnpm (active package manager).
ignore-scripts=true
engine-strict=true
# pnpm-specific
fund=false
audit=false
# Do not re-run `pnpm install` as a deps-status check before `pnpm exec`/`pnpm run`.
# That check is one path that turns ignored build scripts into a FATAL
# ERR_PNPM_IGNORED_BUILDS (exit 1). Disabling it lets `pnpm exec astro build` run
# on Vercel without a redundant, failing sub-install.
verify-deps-before-run=false
# Flat node_modules (npm-like). astro.config.mjs does `import { loadEnv } from
# 'vite'`, and vite is only a transitive dep of astro — pnpm's default isolated
# linker would not expose it at the top level. Hoisting makes that import resolve.
shamefully-hoist=true