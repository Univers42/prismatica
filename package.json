{
  "name": "opposite-osiris",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/container-only.mjs astro dev --host 0.0.0.0 --port 4322",
    "dev:astro": "node scripts/container-only.mjs astro dev",
    "dev:https": "node scripts/container-only.mjs node scripts/dev-https.mjs",
    "build": "node scripts/container-only.mjs astro build",
    "check": "node scripts/container-only.mjs astro check",
    "preview": "node scripts/container-only.mjs astro preview --host 0.0.0.0",
    "astro": "node scripts/container-only.mjs astro",
    "lint": "node scripts/container-only.mjs eslint .",
    "lint:fix": "node scripts/container-only.mjs eslint . --fix",
    "lint:css": "node scripts/container-only.mjs stylelint \"src/**/*.scss\"",
    "lint:css:fix": "node scripts/container-only.mjs stylelint \"src/**/*.scss\" --fix",
    "lint:html": "node scripts/container-only.mjs html-validate \"dist/**/*.html\"",
    "audit:a11y": "node scripts/container-only.mjs pa11y http://127.0.0.1:4322/ --config scripts/audit/pa11y.config.json",
    "audit:csp": "node scripts/container-only.mjs node scripts/audit/csp-check.mjs http://127.0.0.1:4399",
    "audit:all": "node scripts/container-only.mjs node scripts/audit/run-all.mjs",
    "cert:localhost": "node scripts/container-only.mjs sh ../../apps/baas/scripts/generate-localhost-cert.sh",
    "cert:trust": "node scripts/container-only.mjs sh ../../apps/baas/scripts/trust-localhost-cert.sh",
    "auth:gateway": "node scripts/container-only.mjs node scripts/auth-gateway.mjs",
    "test:security": "node scripts/container-only.mjs node scripts/security/run-all.mjs",
    "test:security:ctf": "node scripts/container-only.mjs node scripts/security/ctf/run-all.mjs",
    "test:smtp": "node scripts/container-only.mjs node --env-file=.env.local scripts/verify-smtp.mjs",
    "test:email": "node scripts/container-only.mjs node --env-file=.env.local scripts/verify-email-delivery.mjs",
    "test:templates": "node scripts/container-only.mjs node scripts/verify-templates.mjs",
    "test:newsletter": "node scripts/container-only.mjs node scripts/verify-newsletter-flow.mjs",
    "test:delivery": "node scripts/container-only.mjs node scripts/verify-smtp-delivery.mjs",
    "verify:csp": "node scripts/container-only.mjs node scripts/verify-csp.mjs",
    "verify:sdk-boundaries": "node scripts/container-only.mjs node scripts/verify-sdk-boundaries.mjs",
    "test:ux": "node scripts/container-only.mjs node scripts/verify-notifications.mjs",
    "reset:database": "node scripts/container-only.mjs node ../../apps/baas/scripts/reset-database.mjs",
    "db:reset": "node scripts/container-only.mjs node ../../apps/baas/scripts/reset-database.mjs",
    "db:reset:yes": "node scripts/container-only.mjs node ../../apps/baas/scripts/reset-database.mjs --yes",
    "baas:verify": "node scripts/container-only.mjs sh -lc 'node scripts/verify-connection.mjs && node scripts/verify-schema.mjs && node scripts/verify-seeds.mjs && node scripts/verify-auth.mjs && node scripts/verify-registration-flow.mjs'",
    "baas:verify:cors": "node scripts/container-only.mjs node scripts/verify-cors.mjs",
    "baas:verify:connection": "node scripts/container-only.mjs node scripts/verify-connection.mjs",
    "baas:verify:schema": "node scripts/container-only.mjs node scripts/verify-schema.mjs",
    "baas:verify:seeds": "node scripts/container-only.mjs node scripts/verify-seeds.mjs",
    "baas:verify:auth": "node scripts/container-only.mjs node scripts/verify-auth.mjs",
    "baas:verify:register": "node scripts/container-only.mjs node scripts/verify-registration-flow.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.7.3",
    "@mini-baas/js": "file:../../apps/baas/sdk",
    "astro": "^6.2.1",
    "sanitize-html": "^2.17.4",
    "sass": "^1.94.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "html-validate": "^11.5.0",
    "lighthouse": "^13.3.0",
    "pa11y": "^9.1.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "devalue": "^5.8.1"
  },
  "pnpm": {
    "overrides": {
      "yaml@<2.8.3": "^2.9.0"
    }
  }
}
