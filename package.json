{
  "name": "prismatica",
  "version": "0.1.0",
  "private": true,
  "description": "Prismatica — Polymorphic Data Platform",
  "scripts": {
    "dev:api": "cd apps/data-api && pnpm run dev",
    "dev:frontend": "cd apps/frontend && pnpm run dev",
    "build:api": "cd apps/data-api && pnpm run build",
    "build:frontend": "cd apps/frontend && pnpm run build",
    "typecheck": "cd apps/data-api && pnpm run typecheck && cd ../frontend && pnpm exec tsc --noEmit",
    "lint": "cd apps/frontend && pnpm exec eslint ."
  },
  "license": "MIT"
}
